{
  "info": {
    "name": "PR10 - Корейская косметика",
    "_postman_id": "pr10-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:3020/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "productId", "value": "" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "1. Регистрация",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base}}/auth/register" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@mail.ru\",\n  \"password\": \"123456\",\n  \"first_name\": \"Иван\",\n  \"last_name\": \"Иванов\"\n}"
            }
          },
          "event": []
        },
        {
          "name": "2. Вход (login)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base}}/auth/login" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@mail.ru\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "console.log('Tokens saved!');"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Обновление токенов (refresh)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base}}/auth/refresh" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "body": { "mode": "none" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "console.log('Tokens refreshed!');"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Информация обо мне (me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/auth/me" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "PRODUCTS",
      "item": [
        {
          "name": "5. Список товаров",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/products" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.length > 0) {",
                  "  pm.collectionVariables.set('productId', json[0].id);",
                  "  console.log('First product ID saved: ' + json[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "6. Создать товар",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base}}/products" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Тестовый крем\",\n  \"category\": \"Кремы\",\n  \"description\": \"Тестовый товар\",\n  \"price\": 1500,\n  \"stock\": 10,\n  \"rating\": 4.5\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('productId', json.id);",
                  "console.log('New product ID saved: ' + json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "7. Получить товар по ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/products/{{productId}}" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "8. Обновить товар",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base}}/products/{{productId}}" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1999,\n  \"stock\": 5\n}"
            }
          }
        },
        {
          "name": "9. Удалить товар",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base}}/products/{{productId}}" },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    }
  ]
}
